POSTGRES_DB=doc_generator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
REDIS_PORT=6379
QDRANT_PORT=6333
API_PORT=8000
WEB_PORT=3000
QUEUE_PORT=3010
NEXT_PUBLIC_API_URL=http://localhost:8000
API_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/doc_generator
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
BULLMQ_QUEUE_NAME=repository-analysis
BULLMQ_PREFIX=doc-generator
BULLMQ_WORKER_CONCURRENCY=4
BULLMQ_JOB_ATTEMPTS=3
BULLMQ_JOB_BACKOFF_MS=5000
BULLMQ_JOB_TTL_SECONDS=86400
BULLMQ_HEARTBEAT_FILE=/tmp/bullmq-worker-heartbeat
BULLMQ_PYTHON_COMMAND=/opt/venv/bin/python
BULLMQ_PYTHON_CWD=/workspace/apps/api
BULLMQ_PYTHON_MODULE=app.workers.process_repository_cli
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=code_chunks
QDRANT_DISTANCE_METRIC=Cosine
QDRANT_TIMEOUT_SECONDS=30
QDRANT_MAX_RETRIES=3
QDRANT_WAIT_FOR_INDEXING=false
GEMINI_API_KEY=replace-me
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_BATCH_SIZE=8
GEMINI_EMBEDDING_TIMEOUT_SECONDS=60
GEMINI_EMBEDDING_MAX_RETRIES=3
GEMINI_EMBEDDING_TASK_PREFIX=Represent this code chunk for repository retrieval.
RETRIEVAL_DEFAULT_LIMIT=8
RETRIEVAL_MAX_LIMIT=20
SPARSE_VECTOR_DIMENSIONS=4096
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_GENERATION_TIMEOUT_SECONDS=90
GEMINI_GENERATION_MAX_RETRIES=3
GEMINI_GENERATION_MAX_OUTPUT_TOKENS=4096
DOCUMENTATION_RETRIEVAL_LIMIT=6
DOCUMENTATION_CONTEXT_CHAR_LIMIT=1800
CHAT_RETRIEVAL_LIMIT=6
CHAT_CONTEXT_CHAR_LIMIT=1200
CHAT_SNIPPET_CHAR_LIMIT=600
CHAT_MAX_SNIPPETS=3
CHAT_HISTORY_TTL_SECONDS=86400
CHAT_HISTORY_MAX_MESSAGES=8
CHAT_HISTORY_CHAR_LIMIT=400
QUEUE_API_URL=http://queue-api:3010
GITHUB_WEBHOOK_DELIVERY_TTL_SECONDS=172800
GITHUB_WEBHOOK_MAX_RETRIES=3
OPENAI_API_KEY=replace-me
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
